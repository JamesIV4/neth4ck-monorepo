{
    "name": "neth4ck-monorepo",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "description": "NetHack WebAssembly monorepo — shim + WASM packages",
    "packageManager": "pnpm@10.0.0",
    "engines": {
        "node": ">=18.19.0"
    },
    "scripts": {
        "build": "pnpm exec nx run-many --target=build",
        "test": "pnpm exec vitest run",
        "lint": "pnpm exec nx run-many --target=lint",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "prepare": "husky",
        "prepush": "pnpm format:check && pnpm exec nx run-many -t lint && pnpm exec vitest run"
    },
    "config": {
        "commitizen": {
            "path": "cz-conventional-changelog"
        }
    },
    "devDependencies": {
        "@commitlint/cli": "^19.8.1",
        "@commitlint/config-conventional": "^19.8.1",
        "@eslint/js": "^9.29.0",
        "@nx/js": "22.3.3",
        "commitizen": "^4.3.1",
        "cz-conventional-changelog": "^3.3.0",
        "eslint": "^9.29.0",
        "eslint-plugin-simple-import-sort": "^12.1.1",
        "globals": "^15.12.0",
        "husky": "^9.1.7",
        "nx": "22.3.3",
        "prettier": "^3.4.2",
        "tsx": "^4.20.3",
        "vitest": "^3.2.4"
    }
}
